<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Shokupan AsyncAPI</title>
    <!-- Preload Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
    <style id="theme.css"><%~ include("theme.css") %></style>
    <style id="style.css"><%~ include("style.css") %></style>
</head>
<body>
    <div class="app-container">
        <!-- LEFT: Navigation -->
        <div class="sidebar scroller">
            <div class="sidebar-header">
                <h2>AsyncAPI</h2>
            </div>
            <div class="nav-list" id="nav-list"></div>
        </div>

        <div class="resizer" id="resizer-left"></div>

        <!-- CENTER: Documentation -->
        <main class="main-content scroller" id="doc-panel">
            <div class="empty-state">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                    <path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"></path>
                    <path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"></path>
                </svg>
                <h3>Select an event to view details</h3>
            </div>
        </main>

        <div class="resizer" id="resizer-right"></div>

        <!-- RIGHT: Console -->
        <div class="console-panel">
            <div class="console-header">
                <div class="connection-bar">
                    <select id="protocol">
                        <option value="ws">WS</option>
                        <option value="wss">WSS</option>
                        <option value="socket.io">Socket.IO</option>
                    </select>
                    <div style="width: 1px; background: rgba(255,255,255,0.1); margin: 2px 0;"></div>
                    <input type="text" id="url" value="<%~ it.serverUrl %>">
                </div>
                <div style="display: grid; grid-template-columns: 1fr auto; gap: 8px;">
                    <button id="connect-btn" class="btn">Connect</button>
                    <button id="clear-logs-btn" class="btn secondary" title="Clear Logs">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M3 6h18M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"></path>
                        </svg>
                    </button>
                </div>
                <div class="status-indicator">
                    <div id="status-dot" class="dot"></div>
                    <span id="connection-status">Disconnected</span>
                </div>
            </div>

            <div class="logs-container scroller" id="logs">
                <div class="log-shim" id="log-shim"></div>
            </div>

            <div class="compose-area">
                <div class="compose-header">
                    <span>Payload</span>
                    <span id="target-event" style="color: var(--primary);">--</span>
                </div>
                <div id="editor-container"></div>
                <div class="send-bar">
                    <button id="send-btn" class="btn">Send Message</button>
                </div>
            </div>
        </div>
    </div>

    <!-- Scripts -->
    <script src="https://cdn.socket.io/4.7.4/socket.io.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/monaco-editor/0.45.0/min/vs/loader.min.js"></script>
    <script id="script.js"><%~ include("script.js") %></script>
</body>
</html>