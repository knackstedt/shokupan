---
// docs/src/components/Releases.astro
const response = await fetch('https://api.github.com/repos/knackstedt/shokupan/releases');
const releases = await response.json();
---
<div>
  {releases ? releases.map((release: any) => (
    <details>
      <summary><strong>{release.tag_name}</strong> - {new Date(release.published_at).toLocaleDateString()}</summary>
      <div set:html={release.body}></div>
    </details>
  )) : <div>No releases found</div>}
</div>