---
// Import the default SocialIcons component from Starlight
import Default from '@astrojs/starlight/components/SocialIcons.astro';
---

<!-- Render the default social icons (GitHub, etc.) -->
<Default><slot /></Default>

<!-- Add custom LLMs.txt copy button -->
<a
  href="#"
  class="sl-flex llms-copy-btn"
  title="Copy LLMs.txt URL for AI assistant"
  aria-label="Copy LLMs.txt URL for AI assistant"
>
  <svg
    aria-hidden="true"
    width="16"
    height="16"
    viewBox="0 0 24 24"
    fill="none"
    stroke="currentColor"
    stroke-width="2"
    stroke-linecap="round"
    stroke-linejoin="round"
  >
    <!-- Robot/AI icon -->
    <rect x="3" y="11" width="18" height="10" rx="2"></rect>
    <circle cx="12" cy="5" r="2"></circle>
    <path d="M12 7v4"></path>
    <line x1="8" y1="16" x2="8" y2="16"></line>
    <line x1="16" y1="16" x2="16" y2="16"></line>
  </svg>
  <span class="sr-only">Copy LLMs.txt URL</span>
</a>

<style>
  .llms-copy-btn {
    color: var(--sl-color-text-accent);
    gap: 0.5rem;
    align-items: center;
    border: 0;
    text-decoration: none;
    cursor: pointer;
    position: relative;
  }

  .llms-copy-btn:hover {
    color: var(--sl-color-white);
  }

  .llms-copy-btn svg {
    display: block;
  }

  /* Tooltip for copy confirmation */
  .llms-copy-btn::after {
    content: attr(data-tooltip);
    position: absolute;
    top: 100%;
    left: 50%;
    transform: translateX(-50%) translateY(0.5rem);
    background: var(--sl-color-bg-nav);
    color: var(--sl-color-white);
    padding: 0.25rem 0.5rem;
    border-radius: 0.25rem;
    font-size: 0.75rem;
    white-space: nowrap;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.2s;
    border: 1px solid var(--sl-color-gray-5);
  }

  .llms-copy-btn[data-tooltip]::after {
    opacity: 1;
  }

  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border-width: 0;
  }
</style>

<script>
  // Client-side script for copy functionality
  document.addEventListener('DOMContentLoaded', () => {
    const copyBtn = document.querySelector('.llms-copy-btn');
    
    if (!copyBtn) return;

    copyBtn.addEventListener('click', async (e) => {
      e.preventDefault();
      
      const baseUrl = 'https://knackstedt.github.io/shokupan';
      const llmsUrl = `${baseUrl}/llms.txt`;
      
      // Text to copy - includes helpful prompt for the user
      const textToCopy = `Please read and use the context from this Shokupan framework documentation:
${llmsUrl}

After reading, you can help me with questions about Shokupan.`;

      try {
        await navigator.clipboard.writeText(textToCopy);
        
        // Show success tooltip
        copyBtn.setAttribute('data-tooltip', 'Copied! ✓');
        
        // Remove tooltip after 2 seconds
        setTimeout(() => {
          copyBtn.removeAttribute('data-tooltip');
        }, 2000);
      } catch (err) {
        console.error('Failed to copy:', err);
        
        // Show error tooltip
        copyBtn.setAttribute('data-tooltip', 'Failed to copy');
        setTimeout(() => {
          copyBtn.removeAttribute('data-tooltip');
        }, 2000);
      }
    });
  });
</script>
