{
    "name": "shokupan",
    "version": "0.0.1",
    "description": "Shokupan is a low-lift modern web framework for Bun.",
    "author": "Andrew G. Knackstedt",
    "repository": {
        "url": "https://github.com/knackstedt/shokupan"
    },
    "license": "MIT",
    "keywords": [
        "bun",
        "web",
        "express",
        "koa",
        "elysia",
        "nestjs",
        "http"
    ],
    "type": "module",
    "scripts": {
        "dev": "bun --watch --inspect src/example/main.ts",
        "debug:otel": "sh scripts/debug-otel.sh",
        "build": "vite build"
    },
    "bin": {
        "shokupan": "./dist/cli.js",
        "skp": "./dist/cli.js"
    },
    "files": [
        "dist",
        "package.json",
        "README.md",
        "LICENSE"
    ],
    "private": false,
    "main": "./dist/index.cjs",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js",
            "require": "./dist/index.cjs"
        },
        "./cli": {
            "types": "./dist/cli/index.d.ts",
            "import": "./dist/cli.js",
            "require": "./dist/cli.cjs"
        }
    },
    "dependencies": {
        "@clack/prompts": "^0.11.0",
        "@opentelemetry/api": "^1.9.0",
        "@opentelemetry/exporter-trace-otlp-proto": "^0.208.0",
        "@opentelemetry/resources": "^2.2.0",
        "@opentelemetry/sdk-trace-base": "^2.2.0",
        "@opentelemetry/sdk-trace-node": "^2.2.0",
        "@opentelemetry/semantic-conventions": "^1.38.0",
        "@scalar/api-reference": "^1.40.9",
        "@scalar/openapi-types": "^0.5.3",
        "arctic": "^3.7.0",
        "class-transformer": "^0.5.1",
        "class-validator": "^0.14.3",
        "eta": "^4.5.0",
        "jose": "^6.1.3",
        "reflect-metadata": "^0.2.2",
        "tslib": "^2.8.1"
    },
    "devDependencies": {
        "@sinclair/typebox": "^0.34.45",
        "@tsconfig/bun": "^1.0.8",
        "@types/axios": "^0.9.36",
        "@types/bun": "^1.2.23",
        "@types/supertest": "^6.0.3",
        "ajv": "^8.17.1",
        "axios": "^1.13.2",
        "get-port": "^7.1.0",
        "supertest": "^7.1.4",
        "typescript": "~5.9.3",
        "valibot": "^1.2.0",
        "vite": "^7.3.0",
        "vite-plugin-dts": "^4.5.4",
        "zod": "^4.2.1"
    }
}