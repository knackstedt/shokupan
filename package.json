{
    "name": "shokupan",
    "version": "0.6.0",
    "description": "Shokupan is a low-lift modern web framework for Bun.",
    "author": "Andrew G. Knackstedt",
    "publishConfig": {
        "access": "public",
        "provenance": true
    },
    "repository": {
        "url": "git+https://github.com/knackstedt/shokupan.git"
    },
    "license": "MIT",
    "keywords": [
        "bun",
        "web",
        "express",
        "koa",
        "elysia",
        "nestjs",
        "http"
    ],
    "type": "module",
    "scripts": {
        "dev": "bun --watch --inspect src/example/main.ts",
        "debug:otel": "sh scripts/debug-otel.sh",
        "docs": "cd docs && bun run dev",
        "build": "vite build",
        "bench": "cd src/benchmarking && bun runner.ts",
        "bench:advanced": "cd src/benchmarking && bun advanced-runner.ts",
        "retag": "git push origin :refs/tags/v$(node -p \"require('./package.json').version\") 2>/dev/null || true && git tag -d v$(node -p \"require('./package.json').version\") 2>/dev/null || true && git tag v$(node -p \"require('./package.json').version\") && git push origin v$(node -p \"require('./package.json').version\") --force"
    },
    "bin": {
        "shokupan": "dist/cli.js",
        "skp": "dist/cli.js"
    },
    "files": [
        "dist",
        "package.json",
        "README.md",
        "LICENSE"
    ],
    "private": false,
    "main": "./dist/index.cjs",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js",
            "require": "./dist/index.cjs"
        },
        "./cli": {
            "types": "./dist/cli/index.d.ts",
            "import": "./dist/cli.js",
            "require": "./dist/cli.cjs"
        }
    },
    "dependencies": {
        "@clack/prompts": "^0.11.0",
        "@opentelemetry/api": "^1.9.0",
        "@opentelemetry/exporter-trace-otlp-proto": "^0.208.0",
        "@opentelemetry/resources": "^2.2.0",
        "@opentelemetry/sdk-trace-base": "^2.2.0",
        "@opentelemetry/sdk-trace-node": "^2.2.0",
        "@opentelemetry/semantic-conventions": "^1.38.0",
        "@scalar/openapi-types": "^0.5.3",
        "tslib": "^2.8.1"
    },
    "peerDependencies": {
        "ajv": "^8.0.0",
        "ajv-formats": "^3.0.0",
        "arctic": "^3",
        "class-transformer": "^0.5.0",
        "class-validator": "^0.14.0",
        "eta": "^4.0.0",
        "jose": "^6.0.0",
        "parse-json": "^8.0.0",
        "reflect-metadata": "^0.2.0",
        "secure-json-parse": "^4.0.0",
        "@scalar/api-reference": "^1.0.0",
        "@surrealdb/node": "^2.4.0",
        "surrealdb": "^2.0.0-alpha.14"
    },
    "peerDependenciesMeta": {
        "ajv": {
            "optional": true
        },
        "ajv-formats": {
            "optional": true
        },
        "arctic": {
            "optional": true
        },
        "class-transformer": {
            "optional": true
        },
        "class-validator": {
            "optional": true
        },
        "eta": {
            "optional": true
        },
        "jose": {
            "optional": true
        },
        "parse-json": {
            "optional": true
        },
        "reflect-metadata": {
            "optional": true
        },
        "secure-json-parse": {
            "optional": true
        },
        "@scalar/api-reference": {
            "optional": true
        },
        "@surrealdb/node": {
            "optional": true
        },
        "surrealdb": {
            "optional": true
        }
    },
    "devDependencies": {
        "@scalar/api-reference": "^1.0.0",
        "@sinclair/typebox": "^0.34.45",
        "@surrealdb/node": "^2.4.0",
        "@tsconfig/bun": "^1.0.8",
        "@types/axios": "^0.9.36",
        "@types/bun": "^1.2.23",
        "@types/supertest": "^6.0.3",
        "ajv": "^8.0.0",
        "ajv-formats": "^3.0.0",
        "arctic": "^3",
        "axios": "^1.13.2",
        "class-transformer": "^0.5.0",
        "class-validator": "^0.14.0",
        "eta": "^4.0.0",
        "fast-json-stringify": "^6.1.1",
        "get-port": "^7.1.0",
        "jose": "^6.0.0",
        "parse-json": "^8.0.0",
        "reflect-metadata": "^0.2.0",
        "secure-json-parse": "^4.0.0",
        "supertest": "^7.1.4",
        "surrealdb": "^2.0.0-alpha.14",
        "typescript": "~5.9.3",
        "valibot": "^1.2.0",
        "vite": "^7.3.0",
        "vite-plugin-dts": "^4.5.4",
        "zod": "^4.2.1"
    }
}