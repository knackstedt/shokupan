{
    "name": "shokupan",
    "version": "0.17.1-2",
    "description": "Shokupan is a low-lift modern web framework for Bun.",
    "author": "Andrew G. Knackstedt",
    "publishConfig": {
        "access": "public",
        "provenance": true
    },
    "repository": {
        "url": "git+https://github.com/knackstedt/shokupan.git"
    },
    "license": "MIT",
    "keywords": [
        "bun",
        "web",
        "express",
        "koa",
        "elysia",
        "nestjs",
        "http"
    ],
    "type": "module",
    "scripts": {
        "dev": "bun run scripts/start-dev.ts",
        "dev:server": "bun --watch --inspect examples/full/main.ts",
        "dev:client": "cd client && ng serve",
        "build:client": "cd client && ng build --configuration production",
        "test:client": "cd client && ng test --watch=false",
        "mcp:inspector": "npx @modelcontextprotocol/inspector http://localhost:8372/mcp",
        "debug:otel": "sh scripts/debug-otel.sh",
        "docs": "cd docs && bun run dev",
        "build": "vite build",
        "bench": "cd benchmarking && bun runner.ts",
        "bench:advanced": "cd benchmarking && bun advanced-runner.ts",
        "retag": "git push origin :refs/tags/v$(node -p \"require('./package.json').version\") 2>/dev/null || true && git tag -d v$(node -p \"require('./package.json').version\") 2>/dev/null || true && git tag v$(node -p \"require('./package.json').version\") && git push origin v$(node -p \"require('./package.json').version\") --force"
    },
    "bin": {
        "shokupan": "dist/cli.js",
        "skp": "dist/cli.js"
    },
    "files": [
        "dist",
        "package.json",
        "README.md",
        "LICENSE"
    ],
    "private": false,
    "main": "./dist/index.cjs",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js",
            "require": "./dist/index.cjs"
        },
        "./cli": {
            "types": "./dist/cli/index.d.ts",
            "import": "./dist/cli.js",
            "require": "./dist/cli.cjs"
        }
    },
    "dependencies": {
        "@clack/prompts": "^0.11.0",
        "cockatiel": "^3.2.1",
        "mrmime": "^2.0.1",
        "nanoid": "^5.1.6",
        "node-forge": "^1.3.3",
        "tslib": "^2.8.1"
    },
    "peerDependencies": {
        "@apollo/server": "^5.2.0",
        "@opentelemetry/api": "^1.9.0",
        "@scalar/openapi-types": "^0.5.3",
        "@scalar/types": "^0.6.6",
        "@surrealdb/node": "^3.0.1",
        "ajv": "^8.0.0",
        "ajv-formats": "^3.0.0",
        "arctic": "^3",
        "class-transformer": "^0.5.0",
        "class-validator": "^0.14.0",
        "eta": "^4.0.0",
        "graphql": "^16.12.0",
        "graphql-yoga": "^5.18.0",
        "h3": "^2.0.0",
        "jose": "^6.0.0",
        "js-yaml": "^4.1.1",
        "parse-json": "^8.0.0",
        "reflect-metadata": "^0.2.0",
        "secure-json-parse": "^4.0.0",
        "preact": "^10.0.0",
        "preact-render-to-string": "^6.0.0",
        "socket.io": "^4.8.3",
        "surrealdb": "^2.0.0"
    },
