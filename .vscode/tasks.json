{
    // For more information, visit: https://go.microsoft.com/fwlink/?LinkId=733558
    "version": "2.0.0",
    "tasks": [
        {
            "label": "▶ otel viewer",
            "type": "shell",
            "command": "docker",
            // docker run --rm -it -p 18888:18888 -p 4317:18889 -p 4318:18890 -e ASPIRE_DASHBOARD_UNSECURED_ALLOW_ANONYMOUS=true=true mcr.microsoft.com/dotnet/aspire-dashboard:latest
            "args": [
                "run",
                "--rm",
                "-it",
                "-p",
                "18888:18888",
                "-p",
                "4317:18889",
                "-p",
                "4318:18890",
                "-e",
                "ASPIRE_DASHBOARD_UNSECURED_ALLOW_ANONYMOUS=true",
                "mcr.microsoft.com/dotnet/aspire-dashboard:latest"
            ],
            "isBackground": true,
            "problemMatcher": {
                "owner": "otel",
                "pattern": [
                    {
                        "severity": 1,
                        "message": 3,
                        "file": 2,
                        "kind": "file",
                        "regexp": "^([^ ]+)  ([A-Z]+) ([^ ]+): (.+)$"
                    }
                ],
                "background": {
                    "activeOnStart": true,
                    "beginsPattern": {
                        "regexp": "Aspire.Dashboard.DashboardWebApplication"
                    },
                    "endsPattern": {
                        "regexp": "AI is disabled because there isn't a debug session."
                    }
                }
            }
        },
        {
            "label": "▶ database",
            "type": "shell",
            "command": "surreal",
            "args": [
                "start",
                "--user=root",
                "--pass=root",
                "-A",
                "rocksdb:./database/rocksdb"
            ],
            "options": {
                "env": {
                    "SURREAL_HTTP_MAX_RPC_BODY_SIZE": "10 MiB",
                    "SURREAL_HTTP_MAX_SQL_BODY_SIZE": "10 MiB"
                }
            },
            "isBackground": true,
            "problemMatcher": {
                "owner": "surrealdb",
                "pattern": [
                    {
                        "severity": 1,
                        "file": 2,
                        "message": 3,
                        "kind": "file",
                        "regexp": " (ERROR) surreal::([^:]+): ([^\n]+)"
                    }
                ],
                "background": {
                    "activeOnStart": true,
                    "beginsPattern": {
                        "regexp": "INFO surreal::env: Running"
                    },
                    "endsPattern": {
                        "regexp": "INFO surrealdb::net: Started web server"
                    }
                }
            }
        },
        {
            "label": "▶ docs",
            "type": "shell",
            "command": "bun",
            "args": [
                "run",
                "docs"
            ],
            "isBackground": true,
            "problemMatcher": {
                "owner": "surrealdb",
                "pattern": [
                    {
                        "severity": 1,
                        "file": 2,
                        "message": 3,
                        "kind": "file",
                        "regexp": " (ERROR) surreal::([^:]+): ([^\n]+)"
                    }
                ],
                "background": {
                    "activeOnStart": true,
                    "beginsPattern": {
                        "regexp": "\\$ astro dev"
                    },
                    "endsPattern": {
                        "regexp": "astro  v\\d+\\.\\d+\\.\\d+ ready in \\d+ ms"
                    }
                }
            }
        },
        {
            "label": "▶ benchmark (lite)",
            "type": "shell",
            "command": "bun",
            "args": [
                "run",
                "bench",
                "--",
                "--all"
            ],
            "isBackground": true,
            "problemMatcher": {
                "owner": "bun",
                "pattern": [
                    {
                        "severity": 1,
                        "message": 3,
                        "file": 2,
                        "kind": "file",
                        "regexp": "^([^ ]+)  ([A-Z]+) ([^ ]+): (.+)$"
                    }
                ],
                "background": {
                    "activeOnStart": true,
                    "beginsPattern": {
                        "regexp": "Running full benchmark suite for all frameworks..."
                    },
                    "endsPattern": {
                        "regexp": "✨ All done!"
                    }
                }
            }
        },
        {
            "label": "▶ benchmark (full)",
            "type": "shell",
            "command": "bun",
            "args": [
                "run",
                "bench:advanced",
                "--",
                "--all"
            ],
            "isBackground": true,
            "problemMatcher": {
                "owner": "bun",
                "pattern": [
                    {
                        "severity": 1,
                        "message": 3,
                        "file": 2,
                        "kind": "file",
                        "regexp": "^([^ ]+)  ([A-Z]+) ([^ ]+): (.+)$"
                    }
                ],
                "background": {
                    "activeOnStart": true,
                    "beginsPattern": {
                        "regexp": "Running full benchmark suite for all frameworks..."
                    },
                    "endsPattern": {
                        "regexp": "✨ All done!"
                    }
                }
            }
        },
